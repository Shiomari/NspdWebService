                     <div class="example-item">06:07-7.17</div>
                     <div class="example-item">06:07-7.1</div>`
            };

            return examples[searchType] || '<div class="example-item">Введите кадастровый номер</div>';
        }

        function updateFormatDescription(searchType) {
            const descriptions = {
                1: '<strong>Формат:</strong> РР:ОО:РРРРРРР:УУУУ<br><small>где: РР - регион, ОО - округ, РРРРРРР - район, УУУУ - участок</small>',
                2: '<strong>Формат:</strong> РР | РР:ОО | РР:ОО:РРРРРРР<br><small>где: РР - регион, ОО - округ, РРРРРРР - район</small>',
                4: '<strong>Формат:</strong> РР:КК-Н.П<br><small>где: РР - регион, КК - код, Н - номер, П - подномер</small>',
                5: '<strong>Формат:</strong> РР:КК-Н.П<br><small>где: РР - регион, КК - код, Н - номер, П - подномер</small>',
                7: '<strong>Формат:</strong> РР:КК-Н.П<br><small>где: РР - регион, КК - код, Н - номер, П - подномер</small>'
            };

            const formatElement = document.getElementById('formatDescription');
            if (formatElement) {
                const description = descriptions[searchType] || 'Введите кадастровый номер';
                formatElement.innerHTML = `
                    <div class="mb-2">${description}</div>
                    <div id="examplesContainer" class="small text-muted">
                        <strong>Примеры:</strong>
                        <div id="examplesList" class="mt-1"></div>
                    </div>
                `;

                updateExamples(searchType);
            }
        }

        function updatePlaceholder(input, searchType) {
            const placeholders = {
                1: '23:19:0202007:18',
                2: '23 или 23:19 или 23:19:0202007',
                4: '23:19-4.18',
                5: '61:00-6.569',
                7: '09:07-7.108'
            };

            input.placeholder = placeholders[searchType] || 'Введите номер';
        }

        document.getElementById('searchType').addEventListener('change', function() {
            const numberInput = document.getElementById('cadastralNumber');
            const searchType = parseInt(this.value);

            const currentDigits = numberInput.value.replace(/\D/g, '');

            updatePlaceholder(numberInput, searchType);
            updateFormatDescription(searchType);

            if (currentDigits) {
                numberInput.value = '';

                let formatted = '';
                switch (searchType) {
                    case 1:
                        formatted = autoFormatRealEstate(currentDigits, '', 0);
                        break;
                    case 2:
                        formatted = autoFormatCadastralDivision(currentDigits, '', 0);
                        break;
                    case 4:
                    case 5:
                    case 7:
                        formatted = autoFormatWithHyphen(currentDigits, '', 0);
                        break;
                }

                numberInput.value = formatted;
                validateCadastralNumber(numberInput, searchType);
            } else {
                numberInput.classList.remove('is-invalid', 'is-valid');
            }
        });

        document.addEventListener('DOMContentLoaded', function() {
            const searchTypeSelect = document.getElementById('searchType');
            const numberInput = document.getElementById('cadastralNumber');

            if (searchTypeSelect && numberInput) {
                const initialSearchType = parseInt(searchTypeSelect.value);
                updatePlaceholder(numberInput, initialSearchType);
                updateFormatDescription(initialSearchType);

                if (numberInput.value) {
                    formatCadastralNumber(numberInput, initialSearchType);
                }
            }
        });

        function insertExample(example) {
            const numberInput = document.getElementById('cadastralNumber');
            const searchType = parseInt(document.getElementById('searchType').value);

            numberInput.value = example;
            formatCadastralNumber(numberInput, searchType);
            numberInput.focus();
        }

        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            const mapContainer = document.getElementById('mapContainer');
            const toggleIcon = document.getElementById('toggleIcon');

            sidebar.classList.toggle('collapsed');

            if (sidebar.classList.contains('collapsed')) {
                toggleIcon.className = 'fas fa-chevron-right';
                // Обновить размер карты при скрытии панели
                setTimeout(() => {
                    if (mapState.isInitialized) {
                        mapState.mapWidth = document.getElementById('map').offsetWidth;
                        mapState.mapHeight = document.getElementById('map').offsetHeight;
                        updateTilePositions();
                        if (config.multiPolygonCoordinates.length > 0) {
                            drawMultiPolygon(config.multiPolygonCoordinates);
                        }
                    }
                }, 1000);
            } else {
                toggleIcon.className = 'fas fa-chevron-left';
                // Обновить размер карты при показе панели
                setTimeout(() => {
                    if (mapState.isInitialized) {
                        mapState.mapWidth = document.getElementById('map').offsetWidth;
                        mapState.mapHeight = document.getElementById('map').offsetHeight;
                        updateTilePositions();
                        if (config.multiPolygonCoordinates.length > 0) {
                            drawMultiPolygon(config.multiPolygonCoordinates);
                        }
                    }
                }, 1000);
            }
        }

        // Обновить функцию resize для корректной работы с toggle
        window.addEventListener('resize', function() {
            if (mapState.isInitialized) {
                mapState.mapWidth = document.getElementById('map').offsetWidth;
                mapState.mapHeight = document.getElementById('map').offsetHeight;
                updateTilePositions();
                if (config.multiPolygonCoordinates.length > 0) {
                    drawMultiPolygon(config.multiPolygonCoordinates);
                }
            }
        });
    </script>
}

@functions {
    private string GetPlaceholderForType(SearchType searchType)
    {
        return searchType switch
        {
            SearchType.RealEstate => "23:19:0202007:18",
            SearchType.CadastralDivision => "23 или 23:19 или 23:19:0202007",
            SearchType.AdministrativeTerritorialUnits => "23:19-4.18",
            SearchType.ZOUIT => "61:00-6.569",
            SearchType.TerritorialZones => "09:07-7.108",
            _ => "Введите номер"
        };
    }

    private string GetFormatDescription(SearchType searchType)
    {
        return searchType switch
        {
            SearchType.RealEstate => "<strong>Формат:</strong> РР:ОО:РРРРРРР:УУУУ",
            SearchType.CadastralDivision => "<strong>Формат:</strong> РР | РР:ОО | РР:ОО:РРРРРРР",
            SearchType.AdministrativeTerritorialUnits => "<strong>Формат:</strong> РР:КК-Н.П",
            SearchType.ZOUIT => "<strong>Формат:</strong> РР:КК-Н.П",
            SearchType.TerritorialZones => "<strong>Формат:</strong> РР:КК-Н.П",
            _ => "Введите кадастровый номер"
        };
    }

    private string GetExamplesForType(SearchType searchType)
    {
        return searchType switch
        {
            SearchType.RealEstate =>
                @"<div class='example-item'>23:19:0202007:18</div>",

            SearchType.CadastralDivision =>
                @"<div class='example-item'>23</div>
                  <div class='example-item'>23:19</div>
                  <div class='example-item'>23:19:0202007</div>",

            SearchType.AdministrativeTerritorialUnits =>
                @"<div class='example-item'>23:19-4.18</div>",

            SearchType.ZOUIT =>
                @"<div class='example-item'>61:00-6.569</div>",

            SearchType.TerritorialZones =>
                @"<div class='example-item'>09:07-7.108</div>",

            _ => "<div class='example-item'>Введите кадастровый номер</div>"
        };
    }
}